# ===========================================
# 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值
# cp .env.example .env.local
# ===========================================

# -------------------------------------------
# 站点配置
# -------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=天悦宝贝

# -------------------------------------------
# Sanity CMS 配置
# -------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=your_read_token
# 写入 Token（仅服务端 API 使用，不暴露为 NEXT_PUBLIC_*）
# 用于咨询表单提交等写入操作
SANITY_API_WRITE_TOKEN=your_write_token

# -------------------------------------------
# 表单通知配置
# -------------------------------------------
CONTACT_NOTIFICATION_EMAIL=info@example.com

# -------------------------------------------
# SMTP 邮件配置
# -------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password

# -------------------------------------------
# 企业微信通知配置
# -------------------------------------------
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# -------------------------------------------
# 飞书通知配置
# -------------------------------------------
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_hook_id

# -------------------------------------------
# 统计工具配置
# -------------------------------------------
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=your_baidu_analytics_id
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id
